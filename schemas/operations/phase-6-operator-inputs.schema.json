{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://z-platform.dev/schemas/operations/phase-6-operator-inputs.schema.json",
  "type": "object",
  "required": ["schemaVersion", "items"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "_note": {"type": "string"},
    "items": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "issueItem", "status", "recordOwner", "canonicalTargets"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "issueItem": {"type": "string", "minLength": 1},
          "status": {"const": "PENDING_OPERATOR"},
          "recordOwner": {"type": "string", "minLength": 1},
          "canonicalTargets": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
