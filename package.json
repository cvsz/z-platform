{
  "name": "z-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Clean ZeaZ platform foundation",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test && node --test scripts/test/*.test.mjs",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "keys:validate": "node scripts/validate-api-keys.mjs",
    "keys:check": "node scripts/validate-api-keys.mjs --syntax-only --strict",
    "release:validate": "node scripts/validate-release-templates.mjs"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  }
}
