# Copy to .env for local execution. Never commit .env.

# Generate with: openssl rand -hex 32
Z_PLATFORM_SERVICE_TOKEN=

# Optional upstream AI provider configuration. The gateway health endpoint works
# without these values, but chat and file proxy requests require both.
UPSTREAM_BASE_URL=
AI_GATEWAY_PROVIDER_TOKEN=
UPSTREAM_PROVIDER=openai-compatible

# Loopback host ports
AI_GATEWAY_PORT=8400
AGENT_ORCHESTRATOR_PORT=8500
WORKSPACE_RUNTIME_PORT=8600
BILLING_LEDGER_PORT=8700
AGENT_PROVIDER_PORT=8800

# Real internal URLs produced by compose.yml.
BILLING_LEDGER_URL=http://billing-ledger:8700
AGENT_JOB_STORE_URL=http://agent-provider:8800
AGENT_QUEUE_URL=http://agent-provider:8800
AGENT_AUDIT_URL=http://agent-provider:8800
AGENT_IDENTITY_URL=http://agent-provider:8800
AGENT_SANDBOX_URL=http://agent-provider:8800

# The local Agent Provider persists jobs, queue entries, audit events, workspace
# metadata and backup snapshots in the Docker volume agent-provider-data.
