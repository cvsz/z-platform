# Copy to .env for local execution. Never commit .env.

# Generate with: openssl rand -hex 32
Z_PLATFORM_SERVICE_TOKEN=

# Optional upstream AI provider configuration. The gateway health endpoint works
# without these values, but chat and file proxy requests require both.
UPSTREAM_BASE_URL=
AI_GATEWAY_PROVIDER_TOKEN=
UPSTREAM_PROVIDER=openai-compatible

# Loopback host ports
AI_GATEWAY_PORT=8400
AGENT_ORCHESTRATOR_PORT=8500
WORKSPACE_RUNTIME_PORT=8600
BILLING_LEDGER_PORT=8700

# Real internal URL produced by compose.yml and consumed by ai-gateway.
BILLING_LEDGER_URL=http://billing-ledger:8700

# Not configured by the local stack. The orchestrator runs in memory mode until
# real HTTP provider services implementing the required contracts are deployed.
AGENT_JOB_STORE_URL=
AGENT_QUEUE_URL=
AGENT_AUDIT_URL=
AGENT_IDENTITY_URL=
AGENT_SANDBOX_URL=

# Note: workspace-runtime is available internally at
# http://workspace-runtime:8600, but it does not implement the orchestrator's
# required POST /execute sandbox-provider contract and must not be used as
# AGENT_SANDBOX_URL.
