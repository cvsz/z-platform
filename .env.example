# Copy to .env for local execution. Never commit .env or real credentials.

# -----------------------------------------------------------------------------
# Core service authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
Z_PLATFORM_SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# AI Gateway upstream configuration
# -----------------------------------------------------------------------------
# Option A: single upstream provider. The health endpoint works without these
# values, but chat and file proxy requests require a configured upstream.
UPSTREAM_BASE_URL=
AI_GATEWAY_PROVIDER_TOKEN=
UPSTREAM_PROVIDER=openai-compatible

# Option B: ordered multi-provider chain. When non-empty, this takes precedence
# over the single-provider variables above. Keep the JSON value on one line.
# Providers are attempted in order only for network errors, HTTP 429, and HTTP
# 5xx responses. Other HTTP 4xx responses are not retried.
#
# Supported record fields:
#   name       Stable provider identifier used in logs and response headers.
#   base_url   OpenAI-compatible upstream base URL.
#   api_key    Provider credential. Never commit a real value.
#   provider   Adapter name, currently openai-compatible or anthropic.
#
# Example only; .example domains are not real endpoints:
# UPSTREAM_PROVIDERS_JSON=[{"name":"primary","base_url":"https://provider-a.example/v1","api_key":"replace-me","provider":"openai-compatible"},{"name":"secondary","base_url":"https://provider-b.example/v1","api_key":"replace-me","provider":"openai-compatible"}]
UPSTREAM_PROVIDERS_JSON=

# -----------------------------------------------------------------------------
# Loopback host ports
# -----------------------------------------------------------------------------
ZCHAT_PORT=3021
ZWALLET_PORT=3040
AI_GATEWAY_PORT=8400
AGENT_ORCHESTRATOR_PORT=8500
WORKSPACE_RUNTIME_PORT=8600
BILLING_LEDGER_PORT=8700
AGENT_PROVIDER_PORT=8800

# -----------------------------------------------------------------------------
# Application/runtime controls
# -----------------------------------------------------------------------------
ZCHAT_SESSION_TTL_SECONDS=3600

# Readiness-only deterministic failure injection. Keep false outside an explicit
# local or isolated CI retry test.
AGENT_TEST_FAILURE_INJECTION=false

# -----------------------------------------------------------------------------
# Internal Compose service URLs
# -----------------------------------------------------------------------------
# These Docker DNS names resolve only inside the Compose network.
BILLING_LEDGER_URL=http://billing-ledger:8700
AGENT_JOB_STORE_URL=http://agent-provider:8800
AGENT_QUEUE_URL=http://agent-provider:8800
AGENT_AUDIT_URL=http://agent-provider:8800
AGENT_IDENTITY_URL=http://agent-provider:8800
AGENT_SANDBOX_URL=http://agent-provider:8800

# -----------------------------------------------------------------------------
# Optional host-side staging smoke overrides
# -----------------------------------------------------------------------------
# scripts/staging-smoke.mjs defaults to these loopback endpoints. Override only
# when the tested deployment is reachable at different real URLs.
STAGING_SMOKE_ZCHAT_URL=http://127.0.0.1:3021
STAGING_SMOKE_ZWALLET_URL=http://127.0.0.1:3040
STAGING_SMOKE_AI_GATEWAY_URL=http://127.0.0.1:8400
STAGING_SMOKE_AGENT_ORCHESTRATOR_URL=http://127.0.0.1:8500
STAGING_SMOKE_WORKSPACE_RUNTIME_URL=http://127.0.0.1:8600
STAGING_SMOKE_BILLING_LEDGER_URL=http://127.0.0.1:8700
STAGING_SMOKE_AGENT_PROVIDER_URL=http://127.0.0.1:8800

# Enable only when AGENT_TEST_FAILURE_INJECTION=true and the Agent Provider and
# Agent Orchestrator have been recreated with that environment value.
STAGING_SMOKE_TEST_FAILURE_RETRY=false

# The local Agent Provider persists jobs, queue entries, audit events, workspace
# metadata, and backup snapshots in the Docker volume agent-provider-data.
