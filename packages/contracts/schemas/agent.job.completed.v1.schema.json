{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://z-platform.local/contracts/agent.job.completed.v1.schema.json",
  "title": "agent.job.completed.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "tenant_id",
    "job_id",
    "status",
    "audit"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "event_type": {
      "const": "agent.job.completed.v1"
    },
    "event_version": {
      "const": "v1"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "job_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "cancelled",
        "expired"
      ]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "result_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "id"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "default": []
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "runtime_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "attempt",
        "tool_calls"
      ],
      "properties": {
        "worker_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "tool_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tool",
              "scope",
              "mutating",
              "status"
            ],
            "properties": {
              "tool": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "scope": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              },
              "mutating": {
                "type": "boolean"
              },
              "status": {
                "type": "string",
                "enum": [
                  "succeeded",
                  "failed",
                  "skipped"
                ]
              }
            }
          }
        }
      }
    }
  }
}
